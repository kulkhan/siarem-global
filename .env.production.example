# ==============================================
# oddyCRM Production Environment Variables
# Bu dosyayı .env.production olarak kopyalayın
# ve değerleri güncelleyin
# ==============================================

# Veritabanı
DB_USER=oddycrm
DB_PASSWORD=BURAYA_GUCLU_SIFRE_YAZIN_min16_karakter
DB_NAME=oddycrm

# JWT (en az 32 karakter, rastgele üretin)
JWT_SECRET=BURAYA_EN_AZ_32_KARAKTER_GUCLU_SECRET_YAZIN
JWT_EXPIRES_IN=7d

# Uygulama URL'i (sunucu IP veya domain)
FRONTEND_URL=http://192.168.1.100
APP_PORT=80

# Admin subdomain (bu domaine gelen isteklerde tenant çözümleme atlanır)
ADMIN_DOMAIN=admin.siarem.com

# Google reCAPTCHA v2
# https://www.google.com/recaptcha/admin adresinden alın
# Site key → frontend build'e embed edilir
VITE_RECAPTCHA_SITE_KEY=BURAYA_RECAPTCHA_SITE_KEY_YAZIN
# Secret key → backend server-side doğrulama için
RECAPTCHA_SECRET_KEY=BURAYA_RECAPTCHA_SECRET_KEY_YAZIN
