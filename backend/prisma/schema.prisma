generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
}

enum ShipStatus {
  ACTIVE
  PASSIVE
  SOLD
  SCRAPPED
}

enum ServiceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  REVISED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum EntityType {
  CUSTOMER
  SHIP
  SERVICE
  QUOTE
  INVOICE
  MEETING
  SHIP_CERTIFICATE
}

// ─────────────────────────────────────────
// COMPANY (Tenant)
// ─────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique // e.g. acme.siarem.com
  slug      String   @unique // e.g. acme
  isActive  Boolean  @default(true)
  plan      String?           // free | starter | pro | enterprise
  logoUrl   String?
  // Company profile fields
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String?
  taxNumber String?  @map("tax_number")
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyType  String   @default("MARITIME") @map("company_type")
  modules      String[] @default([]) @map("modules")

  users           User[]
  customers       Customer[]
  contacts        Contact[]
  ships           Ship[]
  services        Service[]
  quotes          Quote[]
  invoices        Invoice[]
  meetings        Meeting[]
  documents       Document[]
  expenses        Expense[]
  serviceTypes    ServiceType[]
  shipTypes       ShipType[]
  auditLogs       AuditLog[]
  products        Product[]
  complaints      Complaint[]
  bankAccounts    CustomerBankAccount[]
  serviceReports  ServiceReport[]
  shipCertificates ShipCertificate[]
  customerNotes   CustomerNote[]

  @@map("companies")
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  companyId String?  @map("company_id") // null for SUPER_ADMIN
  name      String
  email     String
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company?           @relation(fields: [companyId], references: [id])
  assignedServices  Service[]
  createdMeetings   Meeting[]
  uploadedDocs      Document[]
  createdQuotes     Quote[]            @relation("QuoteCreator")
  createdInvoices   Invoice[]
  serviceLogs       ServiceLog[]
  expenses          Expense[]          @relation("ExpenseCreatedBy")
  createdCustomers  Customer[]         @relation("CustomerCreatedBy")
  createdShips      Ship[]             @relation("ShipCreatedBy")
  createdServices   Service[]          @relation("ServiceCreatedBy")
  createdContacts   Contact[]          @relation("ContactCreatedBy")
  auditLogs         AuditLog[]
  assignedCustomers CustomerAssignee[]
  serviceReports    ServiceReport[]    @relation("ServiceReportCreatedBy")
  customerNotes     CustomerNote[]     @relation("CustomerNoteUser")

  @@unique([companyId, email])
  @@map("users")
}

// ─────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────

model Customer {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  shortCode   String
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  taxNumber   String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  company       Company                @relation(fields: [companyId], references: [id])
  contacts      Contact[]
  ships         Ship[]
  services      Service[]
  quotes        Quote[]
  invoices      Invoice[]
  meetings      Meeting[]
  documents     Document[]
  expenses      Expense[]
  complaints    Complaint[]
  bankAccounts  CustomerBankAccount[]
  createdBy     User?                  @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  assignees     CustomerAssignee[]
  customerNotes CustomerNote[]

  @@unique([companyId, shortCode])
  @@map("customers")
}

model CustomerBankAccount {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  customerId String   @map("customer_id")
  bankName   String   @map("bank_name")
  iban       String?
  accountNo  String?  @map("account_no")
  currency   String?
  notes      String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_bank_accounts")
}

model Contact {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  customerId  String
  name        String
  title       String?
  email       String?
  phone       String?
  isPrimary   Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  company   Company  @relation(fields: [companyId], references: [id])
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("ContactCreatedBy", fields: [createdById], references: [id])

  @@map("contacts")
}

// ─────────────────────────────────────────
// SHIP TYPES (IMO Categories)
// ─────────────────────────────────────────

model ShipType {
  id        Int     @id @default(autoincrement())
  companyId String? @map("company_id") // null = global
  name      String
  ciiType   String  // "DWT" or "GT"

  company Company? @relation(fields: [companyId], references: [id])
  ships   Ship[]

  @@map("ship_types")
}

// ─────────────────────────────────────────
// SHIPS
// ─────────────────────────────────────────

model Ship {
  id                    String     @id @default(cuid())
  companyId             String     @map("company_id")
  customerId            String
  name                  String
  imoNumber             String?
  shipTypeId            Int?
  flag                  String?
  grossTonnage          Float?
  dwt                   Float?
  netTonnage            Float?
  builtYear             Int?
  classificationSociety String?    // DNV, BV, LR, ClassNK, etc.
  emissionVerifier      String?    // Normec Verifavia, etc.
  itSystem              String?    // GHG Genius, MRV DCS Voyage, etc.
  adminAuthority        String?
  isLargeVessel         Boolean    @default(true) // > 5000 GT
  status                ShipStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  createdById           String?
  updatedById           String?
  deletedAt             DateTime?
  deletedById           String?

  company      Company           @relation(fields: [companyId], references: [id])
  customer     Customer          @relation(fields: [customerId], references: [id])
  shipType     ShipType?         @relation(fields: [shipTypeId], references: [id])
  services     Service[]
  quoteShips   QuoteShip[]
  meetings     Meeting[]
  documents    Document[]
  expenses     Expense[]
  createdBy    User?             @relation("ShipCreatedBy", fields: [createdById], references: [id])
  certificates ShipCertificate[]

  @@unique([companyId, imoNumber])
  @@map("ships")
}

// ─────────────────────────────────────────
// SERVICE TYPES
// ─────────────────────────────────────────

model ServiceType {
  id          Int     @id @default(autoincrement())
  companyId   String? @map("company_id") // null = global
  nameEn      String
  nameTr      String
  code        String
  category    String?
  description String?

  company  Company?  @relation(fields: [companyId], references: [id])
  services Service[]

  @@map("service_types")
}

// ─────────────────────────────────────────
// SERVICES (actual work items per ship)
// ─────────────────────────────────────────

model Service {
  id             String        @id @default(cuid())
  companyId      String        @map("company_id")
  customerId     String
  shipId         String?
  serviceTypeId  Int?
  assignedUserId String?
  status         ServiceStatus @default(OPEN)
  priority       Priority      @default(MEDIUM)

  // Maritime compliance MP statuses
  euMrvMpStatus  String?
  ukMrvMpStatus  String?
  fuelEuMpStatus String?
  imoDcsStatus   String?
  euEtsStatus    String?
  mohaStatus     String?

  // Billing pipeline
  invoiceReady     Boolean @default(false)
  invoiceReadyNote String?

  statusNote  String?
  notes       String?
  startDate   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String?
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  company      Company      @relation(fields: [companyId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  ship         Ship?        @relation(fields: [shipId], references: [id])
  serviceType  ServiceType? @relation(fields: [serviceTypeId], references: [id])
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])
  createdBy    User?        @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  quotes       Quote[]
  invoices     Invoice[]
  documents    Document[]
  logs         ServiceLog[]
  expenses     Expense[]
  report       ServiceReport?

  @@map("services")
}

// ─────────────────────────────────────────
// SERVICE LOGS (audit trail)
// ─────────────────────────────────────────

model ServiceLog {
  id        String   @id @default(cuid())
  serviceId String
  userId    String?
  action    String   // CREATED | STATUS_CHANGED | BILLING_READY | ASSIGNED | UPDATED
  field     String?
  oldValue  String?
  newValue  String?
  note      String?
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("service_logs")
}

// ─────────────────────────────────────────
// QUOTES (with revision history)
// ─────────────────────────────────────────

model Quote {
  id            String      @id @default(cuid())
  companyId     String      @map("company_id")
  quoteNumber   String      // NNNNN-ODDYSHIP-DDMMYYYY
  revision      Int         @default(1)
  parentQuoteId String?     // links to previous revision

  customerId     String
  serviceId      String?
  createdById    String?
  shipCount      Int         @default(1)
  unitPrice      Float?
  currency       String      @default("EUR")
  totalAmount    Float?
  priceEur       Float?
  priceUsd       Float?
  priceTry       Float?
  quoteDate      DateTime
  validUntil     DateTime?
  status         QuoteStatus @default(DRAFT)
  combinedInvoice Boolean    @default(false)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  updatedById    String?
  deletedAt      DateTime?
  deletedById    String?

  company     Company     @relation(fields: [companyId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  service     Service?    @relation(fields: [serviceId], references: [id])
  createdBy   User?       @relation("QuoteCreator", fields: [createdById], references: [id])
  parentQuote Quote?      @relation("QuoteRevisions", fields: [parentQuoteId], references: [id])
  revisions   Quote[]     @relation("QuoteRevisions")
  quoteShips  QuoteShip[]
  invoices    Invoice[]
  documents   Document[]
  items       QuoteItem[]

  @@unique([companyId, quoteNumber])
  @@map("quotes")
}

// Many-to-many: quotes ↔ ships
model QuoteShip {
  quoteId String
  shipId  String
  notes   String?

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  ship  Ship  @relation(fields: [shipId], references: [id])

  @@id([quoteId, shipId])
  @@map("quote_ships")
}

// ─────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  refNo       String?       // CS-XXXXX or ODA2025XXXXXXXXX
  customerId  String
  serviceId   String?
  quoteId     String?
  createdById String?
  amount      Float
  currency    String        @default("EUR")
  status      InvoiceStatus @default(DRAFT)
  isCombined  Boolean       @default(false)
  invoiceDate DateTime
  dueDate     DateTime?
  sentAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  company   Company   @relation(fields: [companyId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  service   Service?  @relation(fields: [serviceId], references: [id])
  quote     Quote?    @relation(fields: [quoteId], references: [id])
  createdBy User?     @relation(fields: [createdById], references: [id])
  payments  Payment[]
  documents Document[]
  expenses  Expense[]
  items     InvoiceItem[]

  @@unique([companyId, refNo])
  @@map("invoices")
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  currency    String   @default("EUR")
  paymentDate DateTime
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─────────────────────────────────────────
// MEETINGS
// ─────────────────────────────────────────

model Meeting {
  id           String    @id @default(cuid())
  companyId    String    @map("company_id")
  customerId   String
  shipId       String?
  createdById  String?
  meetingType  String    @default("MEETING")  // MEETING | CALL
  title        String
  description  String?
  location     String?
  duration     Int?      // minutes (for CALL type)
  meetingDate  DateTime
  followUpDate DateTime?
  attendees    String?   // JSON string of attendee list
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  updatedById  String?
  deletedAt    DateTime?
  deletedById  String?

  company   Company    @relation(fields: [companyId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
  ship      Ship?      @relation(fields: [shipId], references: [id])
  createdBy User?      @relation(fields: [createdById], references: [id])
  documents Document[]

  @@map("meetings")
}

// ─────────────────────────────────────────
// DOCUMENTS (polymorphic)
// ─────────────────────────────────────────

model Document {
  id               String     @id @default(cuid())
  companyId        String     @map("company_id")
  entityType       EntityType
  displayName      String     // user-friendly name
  storedFilename   String     // {id}_{slug}.ext
  originalFilename String
  mimetype         String?
  size             Int?
  uploadedById     String?
  createdAt        DateTime   @default(now())

  company    Company  @relation(fields: [companyId], references: [id])
  uploadedBy User?    @relation(fields: [uploadedById], references: [id])

  // Polymorphic FK fields
  customerId        String?
  shipId            String?
  serviceId         String?
  quoteId           String?
  invoiceId         String?
  meetingId         String?
  shipCertificateId String? @map("ship_certificate_id")

  customer        Customer?        @relation(fields: [customerId], references: [id])
  ship            Ship?            @relation(fields: [shipId], references: [id])
  service         Service?         @relation(fields: [serviceId], references: [id])
  quote           Quote?           @relation(fields: [quoteId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  meeting         Meeting?         @relation(fields: [meetingId], references: [id])
  shipCertificate ShipCertificate? @relation(fields: [shipCertificateId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─────────────────────────────────────────
// EXPENSES (Masraflar — Gelir & Gider)
// ─────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  type        String   // INCOME | EXPENSE
  category    String?  // Personnel, Office, Travel, Service Cost, Other...
  description String
  amount      Float
  currency    String   @default("TRY")
  date        DateTime
  customerId  String?
  shipId      String?
  serviceId   String?
  invoiceId   String?
  notes       String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  company   Company   @relation(fields: [companyId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  ship      Ship?     @relation(fields: [shipId], references: [id])
  service   Service?  @relation(fields: [serviceId], references: [id])
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  createdBy User?     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@map("expenses")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?  @map("company_id") // null = system-level log
  entityType String             // "Customer", "Ship", "Service", etc.
  entityId   String?
  action     String             // CREATE | UPDATE | DELETE
  userId     String?
  userName   String?            // Snapshot — survives if user deleted
  ipAddress  String?
  hostname   String?
  userAgent  String?
  changes    Json?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// CUSTOMER ASSIGNEES (Müşteri Temsilcileri)
// ─────────────────────────────────────────

model CustomerAssignee {
  customerId String
  userId     String
  assignedAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([customerId, userId])
  @@map("customer_assignees")
}

// ─────────────────────────────────────────
// PRODUCTS (Ürün Kataloğu / Envanter)
// ─────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  code         String
  name         String
  nameEn       String?  @map("name_en")
  unit         String   @default("ADET")
  unitPriceEur Decimal? @map("unit_price_eur") @db.Decimal(14, 4)
  unitPriceUsd Decimal? @map("unit_price_usd") @db.Decimal(14, 4)
  unitPriceTry Decimal? @map("unit_price_try") @db.Decimal(14, 4)
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company       @relation(fields: [companyId], references: [id])
  quoteItems   QuoteItem[]
  invoiceItems InvoiceItem[]

  @@unique([companyId, code])
  @@map("products")
}

// ─────────────────────────────────────────
// QUOTE ITEMS (Teklif Kalemleri)
// ─────────────────────────────────────────

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @map("unit_price") @db.Decimal(14, 4)
  currency    String  @default("USD")
  total       Decimal @db.Decimal(14, 4)
  sortOrder   Int     @default(0) @map("sort_order")

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

// ─────────────────────────────────────────
// INVOICE ITEMS (Fatura Kalemleri)
// ─────────────────────────────────────────

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  productId   String? @map("product_id")
  description String
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @map("unit_price") @db.Decimal(14, 4)
  currency    String  @default("USD")
  total       Decimal @db.Decimal(14, 4)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ─────────────────────────────────────────
// SERVICE REPORTS (Servis Tamamlama Raporu)
// ─────────────────────────────────────────

model ServiceReport {
  id          String   @id @default(cuid())
  serviceId   String   @unique @map("service_id")
  companyId   String   @map("company_id")
  workDone    String   @map("work_done")
  findings    String?
  partsUsed   String?  @map("parts_used")
  reportDate  DateTime @default(now()) @map("report_date")
  status      String   @default("DRAFT")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  service   Service @relation(fields: [serviceId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("ServiceReportCreatedBy", fields: [createdById], references: [id])

  @@map("service_reports")
}

// ─────────────────────────────────────────
// SHIP CERTIFICATES (Gemi Sertifikaları)
// ─────────────────────────────────────────

model ShipCertificate {
  id         String    @id @default(cuid())
  shipId     String    @map("ship_id")
  companyId  String    @map("company_id")
  certType   String    @map("cert_type")
  certNo     String?   @map("cert_no")
  issueDate  DateTime? @map("issue_date")
  expiryDate DateTime  @map("expiry_date")
  issuedBy   String?   @map("issued_by")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")

  ship      Ship       @relation(fields: [shipId], references: [id], onDelete: Cascade)
  company   Company    @relation(fields: [companyId], references: [id])
  documents Document[]

  @@map("ship_certificates")
}

// ─────────────────────────────────────────
// CUSTOMER NOTES (Müşteri Notları)
// ─────────────────────────────────────────

model CustomerNote {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  customerId String   @map("customer_id")
  userId     String   @map("user_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User     @relation("CustomerNoteUser", fields: [userId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@map("customer_notes")
}

// ─────────────────────────────────────────
// COMPLAINTS
// ─────────────────────────────────────────

enum ComplaintType {
  COMPLAINT
  FEEDBACK
  SUGGESTION
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Complaint {
  id           String          @id @default(cuid())
  companyId    String          @map("company_id")
  customerId   String?         @map("customer_id")
  type         ComplaintType   @default(COMPLAINT)
  status       ComplaintStatus @default(OPEN)
  subject      String
  description  String
  responseNote String?         @map("response_note")
  respondedAt  DateTime?       @map("responded_at")
  submittedAt  DateTime        @default(now()) @map("submitted_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  // Optional contact info (for public submissions without customerId)
  contactName  String?  @map("contact_name")
  contactEmail String?  @map("contact_email")

  company  Company   @relation(fields: [companyId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("complaints")
}
